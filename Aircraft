# 💻 Complete Java Solution

```java
import java.util.*;

// Class 1: Aircraft
class Aircraft {
    private int aircraftId;
    private String aircraftModel;
    private double aircraftFuelEfficiency;
    private String aircraftType;

    public int getAircraftId() {
        return aircraftId;
    }

    public void setAircraftId(int aircraftId) {
        this.aircraftId = aircraftId;
    }

    public String getAircraftModel() {
        return aircraftModel;
    }

    public void setAircraftModel(String aircraftModel) {
        this.aircraftModel = aircraftModel;
    }

    public double getAircraftFuelEfficiency() {
        return aircraftFuelEfficiency;
    }

    public void setAircraftFuelEfficiency(double aircraftFuelEfficiency) {
        this.aircraftFuelEfficiency = aircraftFuelEfficiency;
    }

    public String getAircraftType() {
        return aircraftType;
    }

    public void setAircraftType(String aircraftType) {
        this.aircraftType = aircraftType;
    }
}

// Class 2: AircraftUtil
class AircraftUtil {
    private List<Aircraft> aircraftList = new ArrayList<>();

    public void addAircraft(Aircraft aircraft) {
        aircraftList.add(aircraft);
    }

    public Aircraft getAircraftById(int id) {
        for (Aircraft a : aircraftList) {
            if (a.getAircraftId() == id) {
                return a;
            }
        }
        return null;
    }

    public List<Aircraft> getMaxFuelEfficiencyAircraft() {
        List<Aircraft> result = new ArrayList<>();

        if (aircraftList.isEmpty()) {
            return result;
        }

        double max = aircraftList.get(0).getAircraftFuelEfficiency();

        for (Aircraft a : aircraftList) {
            if (a.getAircraftFuelEfficiency() > max) {
                max = a.getAircraftFuelEfficiency();
            }
        }

        for (Aircraft a : aircraftList) {
            if (a.getAircraftFuelEfficiency() == max) {
                result.add(a);
            }
        }

        return result;
    }
}

// Class 3: UserInterface
public class UserInterface {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        AircraftUtil util = new AircraftUtil();

        System.out.println("Enter number of aircraft:");
        int n = sc.nextInt();
        sc.nextLine();

        System.out.println("Enter aircraft details:");
        for (int i = 0; i < n; i++) {
            String input = sc.nextLine();
            String[] data = input.split(":");

            Aircraft a = new Aircraft();
            a.setAircraftId(Integer.parseInt(data[0]));
            a.setAircraftModel(data[1]);
            a.setAircraftFuelEfficiency(Double.parseDouble(data[2]));
            a.setAircraftType(data[3]);

            util.addAircraft(a);
        }

        System.out.println("Enter aircraft ID to search:");
        int searchId = sc.nextInt();

        Aircraft found = util.getAircraftById(searchId);

        if (found != null) {
            System.out.println("\nAircraft Found:");
            System.out.println("Aircraft ID: " + found.getAircraftId());
            System.out.println("Aircraft Model: " + found.getAircraftModel());
            System.out.println("Fuel Efficiency: " + found.getAircraftFuelEfficiency());
            System.out.println("Aircraft Type: " + found.getAircraftType());
        } else {
            System.out.println("Aircraft not found");
        }

        List<Aircraft> maxList = util.getMaxFuelEfficiencyAircraft();

        System.out.println("\nAircraft(s) with Maximum Fuel Efficiency:");
        for (Aircraft a : maxList) {
            System.out.println("Aircraft ID: " + a.getAircraftId() +
                    ", Model: " + a.getAircraftModel() +
                    ", Fuel Efficiency: " + a.getAircraftFuelEfficiency() +
                    ", Type: " + a.getAircraftType());
        }
    }
}
```

