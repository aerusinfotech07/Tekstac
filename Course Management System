# 💻 Complete Java Solution

```java id="6hlx7l"
import java.util.*;

// Class 1: Course
class Course {
    private int courseId;
    private String courseName;
    private double courseFee;
    private String courseType;

    public int getCourseId() {
        return courseId;
    }

    public void setCourseId(int courseId) {
        this.courseId = courseId;
    }

    public String getCourseName() {
        return courseName;
    }

    public void setCourseName(String courseName) {
        this.courseName = courseName;
    }

    public double getCourseFee() {
        return courseFee;
    }

    public void setCourseFee(double courseFee) {
        this.courseFee = courseFee;
    }

    public String getCourseType() {
        return courseType;
    }

    public void setCourseType(String courseType) {
        this.courseType = courseType;
    }
}

// Class 2: CourseUtil
class CourseUtil {
    private List<Course> courseList = new ArrayList<>();

    public void addCourse(Course course) {
        courseList.add(course);
    }

    public Course getCourseById(int id) {
        for (Course c : courseList) {
            if (c.getCourseId() == id) {
                return c;
            }
        }
        return null;
    }

    public List<Course> getMaxFeeCourses() {
        List<Course> result = new ArrayList<>();

        if (courseList.isEmpty()) {
            return result;
        }

        double max = courseList.get(0).getCourseFee();

        for (Course c : courseList) {
            if (c.getCourseFee() > max) {
                max = c.getCourseFee();
            }
        }

        for (Course c : courseList) {
            if (c.getCourseFee() == max) {
                result.add(c);
            }
        }

        return result;
    }
}

// Class 3: UserInterface
public class UserInterface {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        CourseUtil util = new CourseUtil();

        System.out.println("Enter number of courses:");
        int n = sc.nextInt();
        sc.nextLine();

        System.out.println("Enter course details:");
        for (int i = 0; i < n; i++) {
            String input = sc.nextLine();
            String[] data = input.split(":");

            Course c = new Course();
            c.setCourseId(Integer.parseInt(data[0]));
            c.setCourseName(data[1]);
            c.setCourseFee(Double.parseDouble(data[2]));
            c.setCourseType(data[3]);

            util.addCourse(c);
        }

        System.out.println("Enter course ID to search:");
        int searchId = sc.nextInt();

        Course found = util.getCourseById(searchId);

        if (found != null) {
            System.out.println("\nCourse Found:");
            System.out.println("Course ID: " + found.getCourseId());
            System.out.println("Course Name: " + found.getCourseName());
            System.out.println("Course Fee: " + found.getCourseFee());
            System.out.println("Course Type: " + found.getCourseType());
        } else {
            System.out.println("Course not found");
        }

        List<Course> maxList = util.getMaxFeeCourses();

        System.out.println("\nCourse(s) with Maximum Fee:");
        for (Course c : maxList) {
            System.out.println("Course ID: " + c.getCourseId() +
                    ", Name: " + c.getCourseName() +
                    ", Fee: " + c.getCourseFee() +
                    ", Type: " + c.getCourseType());
        }
    }
}
```

