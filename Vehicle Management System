# 💻 Complete Java Solution

```java
import java.util.*;

// Class 1: Vehicle
class Vehicle {
    private int vehicleId;
    private String vehicleModel;
    private double vehicleMileage;
    private String vehicleType;

    public int getVehicleId() {
        return vehicleId;
    }

    public void setVehicleId(int vehicleId) {
        this.vehicleId = vehicleId;
    }

    public String getVehicleModel() {
        return vehicleModel;
    }

    public void setVehicleModel(String vehicleModel) {
        this.vehicleModel = vehicleModel;
    }

    public double getVehicleMileage() {
        return vehicleMileage;
    }

    public void setVehicleMileage(double vehicleMileage) {
        this.vehicleMileage = vehicleMileage;
    }

    public String getVehicleType() {
        return vehicleType;
    }

    public void setVehicleType(String vehicleType) {
        this.vehicleType = vehicleType;
    }
}

// Class 2: VehicleUtil
class VehicleUtil {
    private List<Vehicle> vehicleList = new ArrayList<>();

    public void addVehicle(Vehicle vehicle) {
        vehicleList.add(vehicle);
    }

    public Vehicle getVehicleById(int id) {
        for (Vehicle v : vehicleList) {
            if (v.getVehicleId() == id) {
                return v;
            }
        }
        return null;
    }

    public List<Vehicle> getMaxMileageVehicle() {
        List<Vehicle> result = new ArrayList<>();

        if (vehicleList.isEmpty()) {
            return result;
        }

        double max = vehicleList.get(0).getVehicleMileage();

        for (Vehicle v : vehicleList) {
            if (v.getVehicleMileage() > max) {
                max = v.getVehicleMileage();
            }
        }

        for (Vehicle v : vehicleList) {
            if (v.getVehicleMileage() == max) {
                result.add(v);
            }
        }

        return result;
    }
}

// Class 3: UserInterface
public class UserInterface {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        VehicleUtil util = new VehicleUtil();

        System.out.println("Enter number of vehicles:");
        int n = sc.nextInt();
        sc.nextLine();

        System.out.println("Enter vehicle details:");
        for (int i = 0; i < n; i++) {
            String input = sc.nextLine();
            String[] data = input.split(":");

            Vehicle v = new Vehicle();
            v.setVehicleId(Integer.parseInt(data[0]));
            v.setVehicleModel(data[1]);
            v.setVehicleMileage(Double.parseDouble(data[2]));
            v.setVehicleType(data[3]);

            util.addVehicle(v);
        }

        System.out.println("Enter vehicle ID to search:");
        int searchId = sc.nextInt();

        Vehicle found = util.getVehicleById(searchId);

        if (found != null) {
            System.out.println("\nVehicle Found:");
            System.out.println("Vehicle ID: " + found.getVehicleId());
            System.out.println("Vehicle Model: " + found.getVehicleModel());
            System.out.println("Mileage: " + found.getVehicleMileage());
            System.out.println("Vehicle Type: " + found.getVehicleType());
        } else {
            System.out.println("Vehicle not found");
        }

        List<Vehicle> maxList = util.getMaxMileageVehicle();

        System.out.println("\nVehicle(s) with Maximum Mileage:");
        for (Vehicle v : maxList) {
            System.out.println("Vehicle ID: " + v.getVehicleId() +
                    ", Model: " + v.getVehicleModel() +
                    ", Mileage: " + v.getVehicleMileage() +
                    ", Type: " + v.getVehicleType());
        }
    }
}
```

