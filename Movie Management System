# 💻 Complete Java Solution

```java id="4xq8nv"
import java.util.*;

// Class 1: Movie
class Movie {
    private int movieId;
    private String movieName;
    private double movieRating;
    private String movieType;

    public int getMovieId() {
        return movieId;
    }

    public void setMovieId(int movieId) {
        this.movieId = movieId;
    }

    public String getMovieName() {
        return movieName;
    }

    public void setMovieName(String movieName) {
        this.movieName = movieName;
    }

    public double getMovieRating() {
        return movieRating;
    }

    public void setMovieRating(double movieRating) {
        this.movieRating = movieRating;
    }

    public String getMovieType() {
        return movieType;
    }

    public void setMovieType(String movieType) {
        this.movieType = movieType;
    }
}

// Class 2: MovieUtil
class MovieUtil {
    private List<Movie> movieList = new ArrayList<>();

    public void addMovie(Movie movie) {
        movieList.add(movie);
    }

    public Movie getMovieById(int id) {
        for (Movie m : movieList) {
            if (m.getMovieId() == id) {
                return m;
            }
        }
        return null;
    }

    public List<Movie> getMaxRatedMovies() {
        List<Movie> result = new ArrayList<>();

        if (movieList.isEmpty()) {
            return result;
        }

        double max = movieList.get(0).getMovieRating();

        for (Movie m : movieList) {
            if (m.getMovieRating() > max) {
                max = m.getMovieRating();
            }
        }

        for (Movie m : movieList) {
            if (m.getMovieRating() == max) {
                result.add(m);
            }
        }

        return result;
    }
}

// Class 3: UserInterface
public class UserInterface {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        MovieUtil util = new MovieUtil();

        System.out.println("Enter number of movies:");
        int n = sc.nextInt();
        sc.nextLine();

        System.out.println("Enter movie details:");
        for (int i = 0; i < n; i++) {
            String input = sc.nextLine();
            String[] data = input.split(":");

            Movie m = new Movie();
            m.setMovieId(Integer.parseInt(data[0]));
            m.setMovieName(data[1]);
            m.setMovieRating(Double.parseDouble(data[2]));
            m.setMovieType(data[3]);

            util.addMovie(m);
        }

        System.out.println("Enter movie ID to search:");
        int searchId = sc.nextInt();

        Movie found = util.getMovieById(searchId);

        if (found != null) {
            System.out.println("\nMovie Found:");
            System.out.println("Movie ID: " + found.getMovieId());
            System.out.println("Movie Name: " + found.getMovieName());
            System.out.println("Movie Rating: " + found.getMovieRating());
            System.out.println("Movie Type: " + found.getMovieType());
        } else {
            System.out.println("Movie not found");
        }

        List<Movie> maxList = util.getMaxRatedMovies();

        System.out.println("\nMovies with Maximum Rating:");
        for (Movie m : maxList) {
            System.out.println("Movie ID: " + m.getMovieId() +
                    ", Name: " + m.getMovieName() +
                    ", Rating: " + m.getMovieRating() +
                    ", Type: " + m.getMovieType());
        }
    }
}
```

