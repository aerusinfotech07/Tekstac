# 💻 Complete Java Solution

```java id="9xk4tz"
import java.util.*;

// Class 1: Employee
class Employee {
    private int employeeId;
    private String employeeName;
    private double employeeSalary;
    private String department;

    public int getEmployeeId() {
        return employeeId;
    }

    public void setEmployeeId(int employeeId) {
        this.employeeId = employeeId;
    }

    public String getEmployeeName() {
        return employeeName;
    }

    public void setEmployeeName(String employeeName) {
        this.employeeName = employeeName;
    }

    public double getEmployeeSalary() {
        return employeeSalary;
    }

    public void setEmployeeSalary(double employeeSalary) {
        this.employeeSalary = employeeSalary;
    }

    public String getDepartment() {
        return department;
    }

    public void setDepartment(String department) {
        this.department = department;
    }
}

// Class 2: EmployeeUtil
class EmployeeUtil {
    private List<Employee> employeeList = new ArrayList<>();

    public void addEmployee(Employee employee) {
        employeeList.add(employee);
    }

    public Employee getEmployeeById(int id) {
        for (Employee e : employeeList) {
            if (e.getEmployeeId() == id) {
                return e;
            }
        }
        return null;
    }

    public List<Employee> getMaxSalaryEmployees() {
        List<Employee> result = new ArrayList<>();

        if (employeeList.isEmpty()) {
            return result;
        }

        double max = employeeList.get(0).getEmployeeSalary();

        for (Employee e : employeeList) {
            if (e.getEmployeeSalary() > max) {
                max = e.getEmployeeSalary();
            }
        }

        for (Employee e : employeeList) {
            if (e.getEmployeeSalary() == max) {
                result.add(e);
            }
        }

        return result;
    }
}

// Class 3: UserInterface
public class UserInterface {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        EmployeeUtil util = new EmployeeUtil();

        System.out.println("Enter number of employees:");
        int n = sc.nextInt();
        sc.nextLine();

        System.out.println("Enter employee details:");
        for (int i = 0; i < n; i++) {
            String input = sc.nextLine();
            String[] data = input.split(":");

            Employee e = new Employee();
            e.setEmployeeId(Integer.parseInt(data[0]));
            e.setEmployeeName(data[1]);
            e.setEmployeeSalary(Double.parseDouble(data[2]));
            e.setDepartment(data[3]);

            util.addEmployee(e);
        }

        System.out.println("Enter employee ID to search:");
        int searchId = sc.nextInt();

        Employee found = util.getEmployeeById(searchId);

        if (found != null) {
            System.out.println("\nEmployee Found:");
            System.out.println("Employee ID: " + found.getEmployeeId());
            System.out.println("Employee Name: " + found.getEmployeeName());
            System.out.println("Employee Salary: " + found.getEmployeeSalary());
            System.out.println("Department: " + found.getDepartment());
        } else {
            System.out.println("Employee not found");
        }

        List<Employee> maxList = util.getMaxSalaryEmployees();

        System.out.println("\nEmployees with Maximum Salary:");
        for (Employee e : maxList) {
            System.out.println("Employee ID: " + e.getEmployeeId() +
                    ", Name: " + e.getEmployeeName() +
                    ", Salary: " + e.getEmployeeSalary() +
                    ", Department: " + e.getDepartment());
        }
    }
}
```

