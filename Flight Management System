# 💻 Complete Java Solution

```java id="z8p6kc"
import java.util.*;

// Class 1: Flight
class Flight {
    private int flightId;
    private String flightName;
    private double ticketPrice;
    private String flightType;

    public int getFlightId() {
        return flightId;
    }

    public void setFlightId(int flightId) {
        this.flightId = flightId;
    }

    public String getFlightName() {
        return flightName;
    }

    public void setFlightName(String flightName) {
        this.flightName = flightName;
    }

    public double getTicketPrice() {
        return ticketPrice;
    }

    public void setTicketPrice(double ticketPrice) {
        this.ticketPrice = ticketPrice;
    }

    public String getFlightType() {
        return flightType;
    }

    public void setFlightType(String flightType) {
        this.flightType = flightType;
    }
}

// Class 2: FlightUtil
class FlightUtil {
    private List<Flight> flightList = new ArrayList<>();

    public void addFlight(Flight flight) {
        flightList.add(flight);
    }

    public Flight getFlightById(int id) {
        for (Flight f : flightList) {
            if (f.getFlightId() == id) {
                return f;
            }
        }
        return null;
    }

    public List<Flight> getMaxPriceFlights() {
        List<Flight> result = new ArrayList<>();

        if (flightList.isEmpty()) {
            return result;
        }

        double max = flightList.get(0).getTicketPrice();

        for (Flight f : flightList) {
            if (f.getTicketPrice() > max) {
                max = f.getTicketPrice();
            }
        }

        for (Flight f : flightList) {
            if (f.getTicketPrice() == max) {
                result.add(f);
            }
        }

        return result;
    }
}

// Class 3: UserInterface
public class UserInterface {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        FlightUtil util = new FlightUtil();

        System.out.println("Enter number of flights:");
        int n = sc.nextInt();
        sc.nextLine();

        System.out.println("Enter flight details:");
        for (int i = 0; i < n; i++) {
            String input = sc.nextLine();
            String[] data = input.split(":");

            Flight f = new Flight();
            f.setFlightId(Integer.parseInt(data[0]));
            f.setFlightName(data[1]);
            f.setTicketPrice(Double.parseDouble(data[2]));
            f.setFlightType(data[3]);

            util.addFlight(f);
        }

        System.out.println("Enter flight ID to search:");
        int searchId = sc.nextInt();

        Flight found = util.getFlightById(searchId);

        if (found != null) {
            System.out.println("\nFlight Found:");
            System.out.println("Flight ID: " + found.getFlightId());
            System.out.println("Flight Name: " + found.getFlightName());
            System.out.println("Ticket Price: " + found.getTicketPrice());
            System.out.println("Flight Type: " + found.getFlightType());
        } else {
            System.out.println("Flight not found");
        }

        List<Flight> maxList = util.getMaxPriceFlights();

        System.out.println("\nFlights with Maximum Ticket Price:");
        for (Flight f : maxList) {
            System.out.println("Flight ID: " + f.getFlightId() +
                    ", Name: " + f.getFlightName() +
                    ", Price: " + f.getTicketPrice() +
                    ", Type: " + f.getFlightType());
        }
    }
}
```

