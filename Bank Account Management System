# 💻 Complete Java Solution

```java id="6q4zjp"
import java.util.*;

// Class 1: Account
class Account {
    private int accountId;
    private String accountHolderName;
    private double accountBalance;
    private String accountType;

    public int getAccountId() {
        return accountId;
    }

    public void setAccountId(int accountId) {
        this.accountId = accountId;
    }

    public String getAccountHolderName() {
        return accountHolderName;
    }

    public void setAccountHolderName(String accountHolderName) {
        this.accountHolderName = accountHolderName;
    }

    public double getAccountBalance() {
        return accountBalance;
    }

    public void setAccountBalance(double accountBalance) {
        this.accountBalance = accountBalance;
    }

    public String getAccountType() {
        return accountType;
    }

    public void setAccountType(String accountType) {
        this.accountType = accountType;
    }
}

// Class 2: AccountUtil
class AccountUtil {
    private List<Account> accountList = new ArrayList<>();

    public void addAccount(Account account) {
        accountList.add(account);
    }

    public Account getAccountById(int id) {
        for (Account a : accountList) {
            if (a.getAccountId() == id) {
                return a;
            }
        }
        return null;
    }

    public List<Account> getMaxBalanceAccounts() {
        List<Account> result = new ArrayList<>();

        if (accountList.isEmpty()) {
            return result;
        }

        double max = accountList.get(0).getAccountBalance();

        for (Account a : accountList) {
            if (a.getAccountBalance() > max) {
                max = a.getAccountBalance();
            }
        }

        for (Account a : accountList) {
            if (a.getAccountBalance() == max) {
                result.add(a);
            }
        }

        return result;
    }
}

// Class 3: UserInterface
public class UserInterface {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        AccountUtil util = new AccountUtil();

        System.out.println("Enter number of accounts:");
        int n = sc.nextInt();
        sc.nextLine();

        System.out.println("Enter account details:");
        for (int i = 0; i < n; i++) {
            String input = sc.nextLine();
            String[] data = input.split(":");

            Account a = new Account();
            a.setAccountId(Integer.parseInt(data[0]));
            a.setAccountHolderName(data[1]);
            a.setAccountBalance(Double.parseDouble(data[2]));
            a.setAccountType(data[3]);

            util.addAccount(a);
        }

        System.out.println("Enter account ID to search:");
        int searchId = sc.nextInt();

        Account found = util.getAccountById(searchId);

        if (found != null) {
            System.out.println("\nAccount Found:");
            System.out.println("Account ID: " + found.getAccountId());
            System.out.println("Account Holder Name: " + found.getAccountHolderName());
            System.out.println("Account Balance: " + found.getAccountBalance());
            System.out.println("Account Type: " + found.getAccountType());
        } else {
            System.out.println("Account not found");
        }

        List<Account> maxList = util.getMaxBalanceAccounts();

        System.out.println("\nAccounts with Maximum Balance:");
        for (Account a : maxList) {
            System.out.println("Account ID: " + a.getAccountId() +
                    ", Name: " + a.getAccountHolderName() +
                    ", Balance: " + a.getAccountBalance() +
                    ", Type: " + a.getAccountType());
        }
    }
}
```

